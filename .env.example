# ============================================================
# Iconic Design — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================

# Flask
FLASK_ENV=production
SECRET_KEY=change-this-to-a-long-random-string

# Admin recovery master key (keep this safe and private)
ADMIN_MASTER_KEY=change-this-to-a-secure-master-key

# Database path (defaults to buildcorp.db in project root)
# On production server, point this to a persistent data directory.
# DATABASE_PATH=/var/data/buildcorp.db

# Email (for contact form notifications)
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Server port (optional, defaults to 5001 in dev)
# PORT=8000
